{
  "name": "streaming-ts",
  "version": "1.0.0",
  "description": "Serviços TypeScript (REST, GraphQL, SOAP, gRPC) — eixo cross-linguagem.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:rest": "node dist/rest/server.js",
    "start:graphql": "node dist/graphql/server.js",
    "start:soap": "node dist/soap/server.js",
    "start:grpc": "node dist/grpc/server.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.12.5",
    "@grpc/proto-loader": "0.7.13",
    "express": "4.21.2",
    "graphql": "16.10.0",
    "graphql-yoga": "5.10.4",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "typescript": "5.7.2"
  }
}
